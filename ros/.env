# ROS 2 environment defaults for ros2_aliases.zsh
# Edit this file to match your system and workspace layout.

# ROS distro (matches /opt/ros/<distro>)
ROS_DISTRO=humble

# Primary workspace to source (must contain a src/ dir)
ROS_WORKSPACE="$HOME/dev/exr2/exr2_base"

# Default colcon build command
COLCON_BUILD_CMD="colcon build --symlink-install --parallel-workers $(nproc)"

# Domain ID defaults (set via setrdi if needed)
ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=1
