	name = JuerdMispelblomBeyer
	email = juerd.mispelblombeyer@exrobotics.global
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	rebase = true
	ff = false
[credential]
	helper = cache
[submodule]
	recurse = false
